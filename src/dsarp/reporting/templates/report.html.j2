<!doctype html><html lang="en"><head><meta charset="utf-8"><title>DSARP Stage 1</title>
<style>body{font:15px system-ui;max-width:1200px;margin:auto;padding:2rem;color:#18212b}table{border-collapse:collapse;width:100%;margin:1rem 0}th,td{border:1px solid #ccd4dc;padding:.45rem;text-align:left;vertical-align:top}th{background:#eef3f7}.score{font-variant-numeric:tabular-nums}.warning{color:#8a3b00}</style></head><body>
<h1>DSARP Stage 1 recommendation report</h1><p>Run: {{ metadata.run_id }} · {{ metadata.created_at }}</p>
<h2>Project/version summary</h2><table><tr><th>Project</th><th>Version</th></tr>{% for item in projects %}<tr><td>{{ item.project }}</td><td>{{ item.version_id }}</td></tr>{% endfor %}</table>
<h2>Inputs and filtering</h2><pre>{{ quality | tojson(indent=2) }}</pre>
<h2>Top smell instances</h2><table><tr><th>Rank</th><th>Type</th><th>Smell</th><th>Priority</th><th>Components</th></tr>{% for r in smells %}<tr><td>{{ r.smell_instance_rank }}</td><td>{{ r.smell_type }}</td><td>{{ r.smell_id }}</td><td class="score">{{ '%.3f'|format(r.smell_priority) }}</td><td>{{ r.affected_components }}</td></tr>{% endfor %}</table>
<h2>Global recommendations</h2>{% for r in recommendations %}<article><h3>#{{ r.global_rank }} {{ r.display_name }} — {{ r.affected_component_name }}</h3><p>{{ r.taxonomy_description }} {{ r.intended_effect }}</p><table><tr><th>Smell</th><th>Applicability</th><th>Benefit</th><th>Risk</th><th>Priority</th></tr><tr><td>{{ r.smell_type }} / {{ r.smell_id }}</td><td>{{ '%.3f'|format(r.applicability_score) }}</td><td>{{ '%.3f'|format(r.expected_benefit) }}</td><td>{{ '%.3f'|format(r.estimated_risk) }}</td><td>{{ '%.3f'|format(r.final_priority_score) }}</td></tr></table><details><summary>Evidence and score breakdown</summary><pre>{{ r.rule_evidence }}\n{{ r.score_breakdown }}</pre><p><strong>Implementation:</strong> {{ r.implementation_outline }}</p><p class="warning"><strong>Warning:</strong> {{ r.warning_text }}</p><p><strong>Raw and normalized metrics:</strong> severity={{ r.severity }}, fan-in={{ r.fan_in }}, fan-out={{ r.fan_out }}, LOC={{ r.lines_of_code }}, pressure={{ r.pressure_score }}</p></details></article>{% endfor %}
</body></html>

